# ── 御之旅 MVP — 環境變數（對齊開發規劃建議書 v2 第二節）──
# 複製為 .env.local 後填入；切勿 commit .env.local

# Google Gemini（https://aistudio.google.com → Get API key）
GEMINI_API_KEY=

# Supabase（Dashboard → Settings → API）
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=御之旅

# Cloudflare（本機可略；CI 使用 GitHub Secrets：CF_ACCOUNT_ID、CF_API_TOKEN）
